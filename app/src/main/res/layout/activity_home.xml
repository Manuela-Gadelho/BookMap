<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/gray_bg"
    tools:context=".HomeActivity">

    <!-- App Bar Personalizada -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/blue_primary"
        android:padding="16dp"
        android:elevation="4dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">
        <TextView
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="Minha Estante"
            android:textColor="@color/white"
            android:textSize="20sp"
            android:textStyle="bold"/>
        <TextView
            android:id="@+id/btnSearch"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="BUSCAR"
            android:textColor="@color/white"
            android:textSize="14sp"
            android:textStyle="bold"/>
    </LinearLayout>

    <!-- Filtros de Status -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@color/white"
        android:padding="8dp">
        <Button
            android:id="@+id/btnLendo"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            style="@style/Widget.AppCompat.Button.Borderless"
            android:text="LENDO"
            android:textColor="@color/gray_text"
            android:textStyle="bold"/>
        <Button
            android:id="@+id/btnQueroLer"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            style="@style/Widget.AppCompat.Button.Borderless"
            android:text="QUERO LER"
            android:textColor="@color/gray_text"/>
        <Button
            android:id="@+id/btnLidos"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            style="@style/Widget.AppCompat.Button.Borderless"
            android:text="LIDOS"
            android:textColor="@color/gray_text"/>
    </LinearLayout>

    <!-- Current Reading Card -->
    <LinearLayout
        android:id="@+id/layoutCurrentReading"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@color/white"
        android:padding="16dp"
        android:elevation="2dp"
        android:layout_margin="16dp"
        android:visibility="gone">

        <View
            android:layout_width="80dp"
            android:layout_height="120dp"
            android:background="#CCCCCC"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginLeft="16dp">
            <TextView
                android:text="Leitura Atual"
                android:textSize="12sp"
                android:textColor="@color/blue_primary"
                android:textStyle="bold"
                android:layout_marginBottom="4dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
            <TextView
                android:id="@+id/tvCurrentTitle"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/black"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
            <TextView
                android:id="@+id/tvCurrentAuthor"
                android:textSize="14sp"
                android:textColor="@color/gray_text"
                android:layout_marginBottom="8dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
            <ProgressBar
                android:id="@+id/progressCurrent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:progress="0"
                style="?android:attr/progressBarStyleHorizontal"/>
            <TextView
                android:id="@+id/tvCurrentProgress"
                android:text="0% Concluido"
                android:textSize="12sp"
                android:layout_gravity="end"
                android:textColor="@color/blue_primary"
                android:layout_marginTop="4dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Books List -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerBooks"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="16dp"/>

        <TextView
            android:id="@+id/tvEmptyMessage"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="Nenhum livro encontrado"
            android:textColor="@color/gray_text"
            android:textSize="16sp"
            android:visibility="gone"/>

        <!-- FAB Add Book -->
        <Button
            android:id="@+id/fabAddBook"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_gravity="bottom|end"
            android:layout_margin="16dp"
            android:text="+"
            android:textSize="24sp"
            android:backgroundTint="@color/blue_primary"
            android:textColor="@color/white"
            android:elevation="6dp"/>
    </FrameLayout>

    <!-- Bottom Navigation -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@color/white"
        android:elevation="8dp"
        android:gravity="center"
        android:orientation="horizontal">
        <TextView android:id="@+id/navShelf" android:layout_width="0dp" android:layout_weight="1" android:text="ESTANTE" android:textStyle="bold" android:textColor="@color/blue_primary" android:gravity="center" android:padding="16dp"/>
        <TextView android:id="@+id/navMap" android:layout_width="0dp" android:layout_weight="1" android:text="MAPA" android:textColor="@color/gray_text" android:gravity="center" android:padding="16dp"/>
        <TextView android:id="@+id/navClubs" android:layout_width="0dp" android:layout_weight="1" android:text="CLUBES" android:textColor="@color/gray_text" android:gravity="center" android:padding="16dp"/>
        <TextView android:id="@+id/navProfile" android:layout_width="0dp" android:layout_weight="1" android:text="PERFIL" android:textColor="@color/gray_text" android:gravity="center" android:padding="16dp"/>
    </LinearLayout>
</LinearLayout>
