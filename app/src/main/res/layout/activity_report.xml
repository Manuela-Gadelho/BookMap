<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    tools:context=".ReportActivity">

    <LinearLayout
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#CC0000"
            android:padding="16dp"
            android:elevation="4dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">
            <TextView
                android:id="@+id/btnBack"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="&lt;"
                android:textColor="@color/white"
                android:textSize="24sp"
                android:paddingRight="16dp"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Denunciar"
                android:textColor="@color/white"
                android:textSize="20sp"
                android:textStyle="bold"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Tipo de Denuncia"
                android:textStyle="bold"
                android:textColor="@color/blue_dark"
                android:layout_marginBottom="8dp"/>

            <RadioGroup
                android:id="@+id/radioReportType"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp">
                <RadioButton
                    android:id="@+id/radioUser"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Usuario inadequado"
                    android:textColor="@color/gray_text"
                    android:checked="true"/>
                <RadioButton
                    android:id="@+id/radioContent"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Conteudo inadequado"
                    android:textColor="@color/gray_text"/>
                <RadioButton
                    android:id="@+id/radioSpam"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Spam"
                    android:textColor="@color/gray_text"/>
                <RadioButton
                    android:id="@+id/radioOther"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Outro"
                    android:textColor="@color/gray_text"/>
            </RadioGroup>

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:hint="Descreva o motivo da denuncia">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/editReason"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textMultiLine"
                    android:minLines="4"/>
            </com.google.android.material.textfield.TextInputLayout>

            <Button
                android:id="@+id/btnSubmitReport"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="ENVIAR DENUNCIA"
                android:backgroundTint="#CC0000"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:padding="12dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Sua denuncia sera analisada pela equipe de moderacao."
                android:textColor="@color/gray_text"
                android:textSize="12sp"
                android:gravity="center"
                android:layout_marginTop="16dp"/>
        </LinearLayout>
    </LinearLayout>
</ScrollView>
