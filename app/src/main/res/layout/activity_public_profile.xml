<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    tools:context=".PublicProfileActivity">

    <LinearLayout
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/blue_primary"
            android:padding="16dp"
            android:elevation="4dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">
            <TextView
                android:id="@+id/btnBack"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="&lt;"
                android:textColor="@color/white"
                android:textSize="24sp"
                android:paddingRight="16dp"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Perfil Publico"
                android:textColor="@color/white"
                android:textSize="20sp"
                android:textStyle="bold"/>
        </LinearLayout>

        <!-- Profile Info -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="24dp"
            android:background="@color/gray_bg">

            <View
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:background="@color/gray_text"/>

            <TextView
                android:id="@+id/tvName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nome"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="@color/blue_dark"
                android:layout_marginTop="12dp"/>

            <TextView
                android:id="@+id/tvBio"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Bio do usuario"
                android:textSize="14sp"
                android:textColor="@color/gray_text"
                android:layout_marginTop="8dp"
                android:gravity="center"/>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="12dp">
                <TextView
                    android:id="@+id/tvGenres"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Fantasia, Terror"
                    android:textSize="12sp"
                    android:background="#E0E0E0"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="4dp"
                    android:textColor="@color/blue_dark"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Current Reading -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Leitura Atual"
                android:textStyle="bold"
                android:textColor="@color/blue_dark"
                android:layout_marginBottom="12dp"/>

            <LinearLayout
                android:id="@+id/layoutCurrentReading"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/gray_bg"
                android:padding="16dp"
                android:orientation="horizontal"
                android:visibility="gone">

                <View
                    android:layout_width="50dp"
                    android:layout_height="70dp"
                    android:background="#CCCCCC"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginLeft="12dp">
                    <TextView
                        android:id="@+id/tvCurrentBookTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textStyle="bold"
                        android:textColor="@color/black"/>
                    <TextView
                        android:id="@+id/tvCurrentBookAuthor"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/gray_text"
                        android:textSize="13sp"/>
                    <ProgressBar
                        android:id="@+id/progressCurrentBook"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        style="?android:attr/progressBarStyleHorizontal"/>
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:id="@+id/tvNoReading"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nenhuma leitura em andamento"
                android:textColor="@color/gray_text"
                android:visibility="visible"/>

            <!-- Report Button -->
            <Button
                android:id="@+id/btnReport"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="DENUNCIAR USUARIO"
                android:backgroundTint="#CC0000"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:layout_marginTop="32dp"
                android:padding="12dp"/>
        </LinearLayout>

    </LinearLayout>
</ScrollView>
